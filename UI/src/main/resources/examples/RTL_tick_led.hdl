MODULE: tick_light;
INPUT: btn_activate, VCC, GND, clk, reset;
OUTPUT: red_led;
	MEMORY: isActivated;
	SEQUENCE(2):
		STEP(0):
		    red_led = VCC;
		=> ( VCC ) / ( 1 );
		
                STEP(1):
		    red_led = GND;
		=> ( VCC ) / ( 0 );

	END_SEQUENCE;
	CONTROL RESET (0):

	END_CONTROL;
END_MODULE;